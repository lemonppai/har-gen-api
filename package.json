{
  "name": "har-gen-api",
  "type": "module",
  "version": "0.2.1",
  "license": "MIT",
  "scripts": {
    "start": "node bin/cli.js",
    "build": "esbuild mockServer.js --format=esm --outfile=dist/mockServer.mjs && esbuild mockServer.js --format=cjs --outfile=dist/mockServer.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lemonppai/har-gen-api.git"
  },
  "files": ["index.js", "bin", "dist"],
  "keywords": [
    "har",
    "mock",
    "api",
    "vite"
  ],
  "exports": {
    ".": {
      "import": "./index.js"
    },
    "./vite": {
      "import": "./dist/mockServer.mjs",
      "require": "./dist/mockServer.cjs"
    }
  },
  "bin": {
    "har-gen-api": "bin/cli.js"
  },
  "dependencies": {
    "cfonts": "^3.3.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "json5": "^2.2.3",
    "lodash": "^4.18.1",
    "mockjs": "^1.1.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
